# Environment variables for Solar Panel Cleaner

# Camera settings
CAMERA_DEVICE_ID=0
CAMERA_RESOLUTION_WIDTH=1920
CAMERA_RESOLUTION_HEIGHT=1080

# Serial communication
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=115200

# Detection settings
DETECTION_USE_TWO_STAGE=true
DETECTION_PANEL_MODEL=models/panel_detection.onnx
DETECTION_DIRT_MODEL=models/dirt_classification.onnx
DETECTION_INTERVAL=1
DETECTION_CONFIDENCE=0.5

# Cleaning settings
CLEANING_THRESHOLD=30
CLEANING_COOLDOWN=300

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# Model paths (fallback for single-stage)
MODEL_PATH=models/yolo11n_solar.onnx
